{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main-ui webview (Chrome Layer)",
  "webviews": ["main-ui"],
  "permissions": [
    "core:default",
    "dialog:allow-confirm",
    "dialog:allow-save",
    "dialog:allow-open",
    "allow-create-pane-webview",
    "allow-destroy-pane-webview",
    "allow-set-pane-bounds",
    "allow-set-pane-visible",
    "allow-reload-pane",
    "allow-eval-in-pane",
    "allow-focus-webview",
    "allow-popup-pane-menu",
    "allow-popup-workspace-menu",
    "allow-load-persisted-state",
    "allow-save-persisted-state",
    "allow-export-config-file",
    "allow-import-config-file",
    "allow-complete-shutdown"
  ]
}
